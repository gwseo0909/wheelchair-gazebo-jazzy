<?xml version="1.0"?>

<sdf version="1.10">
  <model name="wheelchair">

    <!--
      좌표 기준
      x축: 휠체어 앞쪽
      y축: 휠체어 왼쪽
      z축: 위쪽

      모델 원점:
      지면 z = 0
    -->

    <pose>0 0 0 0 0 0</pose>

    <!-- ================================================== -->
    <!-- 본체                                               -->
    <!-- ================================================== -->

    <link name="base_link">

      <inertial>
        <pose>0 0 0.20 0 0 0</pose>

        <mass>40.0</mass>

        <inertia>
          <ixx>2.0</ixx>
          <iyy>2.5</iyy>
          <izz>2.5</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <!-- 아래쪽 섀시 -->

      <collision name="base_collision">
        <pose>0 0 0.33 0 0 0</pose>

        <geometry>
          <box>
            <size>0.72 0.52 0.16</size>
          </box>
        </geometry>
      </collision>

      <visual name="base_visual">
        <pose>0 0 0.33 0 0 0</pose>

        <geometry>
          <box>
            <size>0.72 0.52 0.16</size>
          </box>
        </geometry>

        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
          <specular>0.10 0.10 0.10 1</specular>
        </material>
      </visual>

      <!-- 좌석 -->

      <collision name="seat_collision">
        <pose>-0.04 0 0.48 0 0 0</pose>

        <geometry>
          <box>
            <size>0.45 0.46 0.10</size>
          </box>
        </geometry>
      </collision>

      <visual name="seat_visual">
        <pose>-0.04 0 0.48 0 0 0</pose>

        <geometry>
          <box>
            <size>0.45 0.46 0.10</size>
          </box>
        </geometry>

        <material>
          <ambient>0.05 0.05 0.12 1</ambient>
          <diffuse>0.10 0.10 0.35 1</diffuse>
          <specular>0.08 0.08 0.08 1</specular>
        </material>
      </visual>

      <!-- 등받이 -->

      <collision name="backrest_collision">
        <pose>-0.24 0 0.82 0 0 0</pose>

        <geometry>
          <box>
            <size>0.10 0.46 0.68</size>
          </box>
        </geometry>
      </collision>

      <visual name="backrest_visual">
        <pose>-0.24 0 0.82 0 0 0</pose>

        <geometry>
          <box>
            <size>0.10 0.46 0.68</size>
          </box>
        </geometry>

        <material>
          <ambient>0.05 0.05 0.12 1</ambient>
          <diffuse>0.10 0.10 0.35 1</diffuse>
          <specular>0.08 0.08 0.08 1</specular>
        </material>
      </visual>

    </link>

    <!-- ================================================== -->
    <!-- 왼쪽 구동바퀴                                     -->
    <!-- ================================================== -->

    <link name="left_drive_wheel">

      <!-- cylinder의 local z축을 모델 y축에 맞춤 -->
      <pose>-0.13 0.31 0.28 1.5708 0 0</pose>

      <inertial>
        <mass>6.0</mass>

        <inertia>
          <ixx>0.119</ixx>
          <iyy>0.235</iyy>
          <izz>0.119</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.28</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>

        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.28</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>

        <material>
          <ambient>0.03 0.03 0.03 1</ambient>
          <diffuse>0.08 0.08 0.08 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>

    </link>

    <joint name="left_drive_wheel_joint" type="revolute">

      <parent>base_link</parent>
      <child>left_drive_wheel</child>

      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>

        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>100</effort>
          <velocity>20</velocity>
        </limit>

        <dynamics>
          <damping>0.1</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>

    </joint>

    <!-- ================================================== -->
    <!-- 오른쪽 구동바퀴                                   -->
    <!-- ================================================== -->

    <link name="right_drive_wheel">

      <pose>-0.13 -0.31 0.28 1.5708 0 0</pose>

      <inertial>
        <mass>6.0</mass>

        <inertia>
          <ixx>0.119</ixx>
          <iyy>0.235</iyy>
          <izz>0.119</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.28</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>

        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.28</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>

        <material>
          <ambient>0.03 0.03 0.03 1</ambient>
          <diffuse>0.08 0.08 0.08 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>

    </link>

    <joint name="right_drive_wheel_joint" type="revolute">

      <parent>base_link</parent>
      <child>right_drive_wheel</child>

      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>

        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
          <effort>100</effort>
          <velocity>20</velocity>
        </limit>

        <dynamics>
          <damping>0.1</damping>
          <friction>0.0</friction>
        </dynamics>
      </axis>

    </joint>

    <!-- ================================================== -->
    <!-- 앞쪽 왼쪽 캐스터                                  -->
    <!-- ================================================== -->

    <link name="front_left_caster">

      <pose>0.31 0.21 0.08 0 0 0</pose>

      <inertial>
        <mass>1.0</mass>

        <inertia>
          <ixx>0.003</ixx>
          <iyy>0.003</iyy>
          <izz>0.003</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="front_left_caster_collision">
        <geometry>
          <sphere>
            <radius>0.08</radius>
          </sphere>
        </geometry>

        <surface>
          <friction>
            <ode>
              <mu>0.1</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="front_left_caster_visual">
        <geometry>
          <sphere>
            <radius>0.08</radius>
          </sphere>
        </geometry>

        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>

    </link>

    <joint name="front_left_caster_joint" type="fixed">
      <parent>base_link</parent>
      <child>front_left_caster</child>
    </joint>

    <!-- ================================================== -->
    <!-- 앞쪽 오른쪽 캐스터                                -->
    <!-- ================================================== -->

    <link name="front_right_caster">

      <pose>0.31 -0.21 0.08 0 0 0</pose>

      <inertial>
        <mass>1.0</mass>

        <inertia>
          <ixx>0.003</ixx>
          <iyy>0.003</iyy>
          <izz>0.003</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="front_right_caster_collision">
        <geometry>
          <sphere>
            <radius>0.08</radius>
          </sphere>
        </geometry>

        <surface>
          <friction>
            <ode>
              <mu>0.1</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="front_right_caster_visual">
        <geometry>
          <sphere>
            <radius>0.08</radius>
          </sphere>
        </geometry>

        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>

    </link>

    <joint name="front_right_caster_joint" type="fixed">
      <parent>base_link</parent>
      <child>front_right_caster</child>
    </joint>

    <!-- ================================================== -->
    <!-- 2D LiDAR                                           -->
    <!-- ================================================== -->

    <link name="lidar_link">

      <!-- 휠체어 앞쪽 상단 -->
      <pose>0.30 0 0.72 0 0 0</pose>

      <inertial>
        <mass>0.5</mass>

        <inertia>
          <ixx>0.001</ixx>
          <iyy>0.001</iyy>
          <izz>0.001</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>

      <collision name="lidar_collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="lidar_visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>

        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
          <specular>0.10 0.10 0.10 1</specular>
        </material>
      </visual>

      <sensor name="lidar_sensor" type="gpu_lidar">

        <pose>0 0 0.03 0 0 0</pose>

        <topic>/model/wheelchair/scan</topic>

        <update_rate>10</update_rate>
        <always_on>true</always_on>
        <visualize>true</visualize>

        <lidar>

          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159265</min_angle>
              <max_angle>3.14159265</max_angle>
            </horizontal>
          </scan>

          <range>
            <min>0.12</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>

          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>

        </lidar>

      </sensor>

    </link>

    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent>
      <child>lidar_link</child>
    </joint>

    <!-- ================================================== -->
    <!-- Gazebo DiffDrive                                   -->
    <!-- ================================================== -->

    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">

      <left_joint>left_drive_wheel_joint</left_joint>
      <right_joint>right_drive_wheel_joint</right_joint>

      <wheel_separation>0.62</wheel_separation>
      <wheel_radius>0.28</wheel_radius>

      <topic>/model/wheelchair/cmd_vel</topic>

      <odom_topic>/model/wheelchair/odometry</odom_topic>
      <tf_topic>/model/wheelchair/tf</tf_topic>

      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>

      <odom_publish_frequency>30</odom_publish_frequency>

      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>

    </plugin>

  </model>
</sdf>